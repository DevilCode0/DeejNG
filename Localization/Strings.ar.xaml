    <sys:String x:Key="Str_Msg_SettingsSaveFailed">فشل حفظ الإعدادات.</sys:String>
    <sys:String x:Key="Str_Msg_StartupDisableFailed_Body">فشل تعطيل التشغيل عند بدء النظام: {0}</sys:String>
    <sys:String x:Key="Str_Msg_StartupEnableFailed_Body">فشل تفعيل التشغيل عند بدء النظام: {0}</sys:String>
