<Window x:Class="DeejNG.Dialogs.ButtonSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{DynamicResource Str_BtnSettings_Title}" Height="901" Width="800"
        FlowDirection="{DynamicResource AppFlowDirection}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource TextPrimaryBrush}"
        Background="{DynamicResource BackgroundBrush}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="12"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Ideal">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <shell:WindowChrome x:Key="Chrome" CaptionHeight="0" CornerRadius="8,8,8,8" ResizeBorderThickness="0" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
        </ResourceDictionary>
    </Window.Resources>
    <shell:WindowChrome.WindowChrome>
        <StaticResource ResourceKey="Chrome" />
    </shell:WindowChrome.WindowChrome>
    <DockPanel Margin="0,0,0,10">
        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}">
            <Grid Height="48" MouseLeftButtonDown="TitleBar_MouseDown" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="🎮" FontSize="24" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="{DynamicResource Str_BtnSettings_Title}" Style="{StaticResource TitleTextBlock}" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="2" Content="✕" Style="{StaticResource IconButton}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        ToolTip="{DynamicResource Str_Close}" Click="CloseButton_Click" Margin="8,0"/>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="{DynamicResource Str_BtnSettings_Section}" Style="{StaticResource TitleTextBlock}" FontSize="18" Margin="0,0,0,16"/>
                    <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Str_BtnSettings_Configure}"
                                       Style="{StaticResource SubtitleTextBlock}"
                                       Margin="0,0,0,8"/>

                            <Border Background="{DynamicResource InfoBackgroundBrush}"
                                    BorderBrush="{DynamicResource InfoBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock TextWrapping="Wrap" Style="{StaticResource SubtitleTextBlock}">
                                    <Run Text="{DynamicResource Str_BtnSettings_AutoDetect}" FontWeight="SemiBold"/>
                                    <LineBreak/>
                                    <Run Text="{DynamicResource Str_BtnSettings_Send}"/>
                                    <LineBreak/>
                                    <Run Text="{DynamicResource Str_BtnSettings_Example}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <ItemsControl x:Name="ButtonMappingsItemsControl" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="12"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="100"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding ButtonIndexDisplay}"
                                                               Style="{StaticResource LabelTextBlock}"
                                                               VerticalAlignment="Center"/>

                                                    <ComboBox Grid.Column="1"
                                                              SelectedIndex="{Binding ActionIndex, Mode=TwoWay}"
                                                              Style="{StaticResource ModernComboBox}"
                                                              Margin="8,0"
                                                              SelectionChanged="ButtonAction_SelectionChanged">
                                                        <ComboBoxItem Content="{DynamicResource Str_Action_None}"/>
                                                        <ComboBoxItem Content="{DynamicResource Str_Action_PlayPause}"/>
                                                        <ComboBoxItem Content="{DynamicResource Str_Action_Next}"/>
                                                        <ComboBoxItem Content="{DynamicResource Str_Action_Previous}"/>
                                                        <ComboBoxItem Content="{DynamicResource Str_Action_Stop}"/>
                                                        <ComboBoxItem Content="{DynamicResource Str_Action_MuteChannel}"/>
                                                        <ComboBoxItem Content="{DynamicResource Str_Action_GlobalMute}"/>
                                                        <ComboBoxItem Content="{DynamicResource Str_Action_Shortcut}"/>
                                                    </ComboBox>

                                                    <TextBox Grid.Column="2"
                                                             Text="{Binding TargetChannelDisplay, Mode=TwoWay}"
                                                             IsEnabled="{Binding NeedsTargetChannel}"
                                                             ToolTip="{DynamicResource Str_BtnSettings_TargetChannel}"
                                                             PreviewTextInput="NumberValidationTextBox"/>
                                                </Grid>
                                                <Grid Visibility="{Binding KeyCaptureVisibility}"
                                                      Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{DynamicResource Str_BtnSettings_Shortcut}"
                                                               Style="{StaticResource LabelTextBlock}"
                                                               VerticalAlignment="Center"/>
                                                    <TextBox Grid.Column="1"
                                                             IsReadOnly="True"
                                                             Text="{Binding KeyComboDisplay, Mode=OneWay}"
                                                             ToolTip="{DynamicResource Str_BtnSettings_ShortcutTooltip}"
                                                             Margin="8,0,0,0"
                                                             PreviewKeyDown="ButtonKeyCombo_PreviewKeyDown"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                    <Button Content="{DynamicResource Str_Save}" Style="{StaticResource ModernButton}" Click="Save_Click" Margin="0,0,10,0"/>
                    <Button Content="{DynamicResource Str_Cancel}" Style="{StaticResource ModernButton}" Click="Cancel_Click"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
